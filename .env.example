# Delhi Scheme Saathi - Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/delhi_scheme_saathi

# xAI (Grok) API - OpenAI-compatible endpoint
XAI_API_KEY=xai-...
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Embeddings (Jina AI primary, Voyage AI fallback)
# Jina AI - 10M free tokens, 89 languages including Hindi/Bengali/Urdu
# Get your API key at: https://jina.ai/embeddings/
JINA_API_KEY=jina_...

# Voyage AI (fallback) - 27 languages, Bengali only for Indian languages
VOYAGE_API_KEY=pa-...

# Voice Services (Phase 5)
# Sarvam AI is preferred - 1000 free credits on signup
# Get your API key at: https://console.sarvam.ai/
SARVAM_API_KEY=

# Bhashini (fallback if Sarvam not configured)
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_ULCA_API_KEY=

# AWS (Phase 6)
AWS_REGION=ap-south-1
SESSION_TABLE_NAME=dss-sessions
AUDIO_BUCKET=dss-audio

# AWS Bedrock LLM (primary, requires AWS credentials)
# Set USE_BEDROCK=true to use Bedrock as primary LLM with Grok as fallback
USE_BEDROCK=false
BEDROCK_MODEL=amazon.nova-2-lite-v1:0

# AI memory queue
# Local default: in_memory
# AWS Lambda production: sqs (SAM deploy now creates the queue automatically)
AI_MEMORY_QUEUE_ENABLED=true
AI_MEMORY_QUEUE_BACKEND=in_memory
AI_MEMORY_QUEUE_URL=

# Application
LOG_LEVEL=INFO
DEBUG=false
