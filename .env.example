# Delhi Scheme Saathi - Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/delhi_scheme_saathi

# xAI (Grok) API - OpenAI-compatible endpoint
XAI_API_KEY=xai-...
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-1-fast-reasoning

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Voyage AI for embeddings
VOYAGE_API_KEY=pa-...

# Bhashini Voice (Phase 5)
BHASHINI_API_KEY=
BHASHINI_USER_ID=
BHASHINI_ULCA_API_KEY=

# AWS (Phase 6)
AWS_REGION=ap-south-1
SESSION_TABLE_NAME=dss-sessions
AUDIO_BUCKET=dss-audio

# Application
LOG_LEVEL=INFO
DEBUG=false
